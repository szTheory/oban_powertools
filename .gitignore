# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# Local agent and Finder scratch.
.DS_Store
/_build_phase23/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
oban_powertools-*.tar

# examples/hex_consumer generated and lock artifacts (not committed — hex dep, no lock).
examples/hex_consumer/mix.lock
examples/hex_consumer/priv/repo/migrations/
examples/hex_consumer/_build/
examples/hex_consumer/deps/

# GSD / agent run scratch artifacts (root-level, never committed).
/audit_uat.json
/discuss_mode.txt
/progress_bar.txt
/progress_init.json
/roadmap.json
/state.json
/summary*.txt
/test_output.txt
*.patch
